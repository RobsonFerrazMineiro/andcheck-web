{
  "name": "andcheck-web",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.5.3",
  "engines": {
    "node": ">=20.9.0",
    "pnpm": ">=11.5.3"
  },
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc -p tsconfig.build.json --noEmit --pretty false",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "lighthouse:auth": "node scripts/lighthouse-authenticated.mjs",
    "qa": "pnpm typecheck && pnpm lint && pnpm test && pnpm qa:static",
    "qa:static": "node scripts/qa-static-check.mjs",
    "homolog:check": "node scripts/check-homolog-env.mjs",
    "analyze:bundle": "node scripts/analyze-next-build.mjs",
    "prisma": "prisma",
    "files:migrate-base64": "node scripts/migrate-base64-files.mjs",
    "db:seed": "node prisma/seed.cjs",
    "db:seed:users": "node prisma/seed-users.cjs"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "@vercel/blob": "^2.4.0",
    "bcryptjs": "3.0.3",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "date-fns": "4.3.0",
    "geist": "^1.7.2",
    "jspdf": "4.2.1",
    "leaflet": "1.9.4",
    "lucide-react": "1.17.0",
    "next": "16.2.6",
    "next-auth": "5.0.0-beta.31",
    "pg": "8.21.0",
    "qrcode": "1.5.4",
    "radix-ui": "1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-leaflet": "5.0.0",
    "recharts": "3.8.1",
    "shadcn": "4.8.2",
    "sonner": "2.0.7",
    "tailwind-merge": "3.6.0",
    "tw-animate-css": "1.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/leaflet": "1.9.21",
    "@types/node": "20.19.41",
    "@types/pg": "8.20.0",
    "@types/qrcode": "1.5.6",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@vitest/coverage-v8": "^4.1.9",
    "dotenv": "17.4.2",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "happy-dom": "^20.10.6",
    "lighthouse": "^13.4.0",
    "prisma": "7.8.0",
    "tailwindcss": "4.3.0",
    "typescript": "5.9.3",
    "vitest": "^4.1.9"
  }
}
