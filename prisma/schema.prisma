// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ──────────────────────────────────────────────────────────────────────────────
// Enums
// ──────────────────────────────────────────────────────────────────────────────

enum ScaffoldStatus {
  em_montagem
  pendente_liberacao
  liberado
  reprovado
  interditado
  vencido
  desmontado
}

enum ScaffoldType {
  tubular
  fachadeiro
  multidirecional
  suspenso
  torre
}

enum InspectionResult {
  aprovado
  aprovado_com_ressalvas
  reprovado
}

enum ChecklistValue {
  CL_OK
  CL_FAIL
  CL_WARN
  CL_NA
}

enum LegacyUserRole {
  admin
  inspector
  viewer

  @@map("UserRole")
}

enum DocumentType {
  ART
  RRT
  MEMORIAL_CALCULO
  CROQUI
  PROJETO
  PROCEDIMENTO
  CERTIFICADO
  OUTRO
}

enum DocumentCategory {
  ART
  RRT
  PROJETO_ESTRUTURAL
  MEMORIAL_CALCULO
  CROQUI
  PLANO_MONTAGEM
  CERTIFICADO_TECNICO
  OUTRO
}

enum DocumentStatus {
  ACTIVE
  EXPIRED
  ARCHIVED
}

enum AuditEntityType {
  COMPANY
  WORKSPACE
  SCAFFOLD
  INSPECTION
  DOCUMENT
  USER
  SIGNATURE
  PDF
  QR_CODE
  SETTINGS
  NON_CONFORMITY
}

enum AuditAction {
  COMPANY_CREATED
  COMPANY_UPDATED
  COMPANY_LOGO_UPDATED
  COMPANY_ACTIVATED
  COMPANY_DEACTIVATED
  WORKSPACE_CREATED
  WORKSPACE_UPDATED
  WORKSPACE_ACTIVATED
  WORKSPACE_DEACTIVATED
  CREATE
  UPDATE
  DELETE
  STATUS_CHANGE
  SIGN
  COMPLETE
  UPLOAD
  DOWNLOAD
  GENERATE_PDF
  VIEW_QR
  LOGIN
  LOGOUT
  ROLE_CHANGE
  USER_PASSWORD_CHANGED
  DOCUMENT_CREATED
  DOCUMENT_UPDATED
  DOCUMENT_VIEWED
  DOCUMENT_ARCHIVED
  DOCUMENT_DOWNLOADED
}

enum NonConformityClassification {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum NonConformityStatus {
  OPEN
  ASSIGNED
  IN_PROGRESS
  PENDING_VERIFICATION
  CLOSED
  REJECTED
  CANCELLED
}

enum NonConformityEvidenceType {
  PHOTO
  PDF
  ART
  MEMORIAL_CALCULO
  CROQUI
  DOCUMENT
  OTHER
}

enum CompanyType {
  CONTRACTOR
  HSE_MANAGER
  SCAFFOLD_COMPANY
  CLIENT
}

enum CompanyWorkspaceRole {
  OWNER
  HSE_MANAGER
  SCAFFOLD_COMPANY
}

model Company {
  id          String      @id @default(cuid())
  name        String      @unique
  code        String      @unique
  tradeName   String?
  cnpj        String?     @unique
  type        CompanyType
  active      Boolean     @default(true)
  description String?
  logoUrl     String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  ownedWorkspaces            Workspace[]                 @relation("WorkspaceOwner")
  users                      User[]
  scaffolds                  Scaffold[]
  inspections                Inspection[]
  nonConformities            NonConformity[]
  auditLogs                  AuditLog[]
  scaffoldDocuments          ScaffoldDocument[]
  documents                  Document[]
  nonConformityEvidences     NonConformityEvidence[]
  nonConformityItemEvidences NonConformityItemEvidence[]
  inspectionSignatures       InspectionSignature[]
  workspaceLinks             CompanyWorkspace[]

  @@index([type, active])
  @@map("companies")
}

model Workspace {
  id             String   @id @default(cuid())
  name           String   @unique
  code           String   @unique
  city           String?
  state          String?
  address        String?
  latitude       Float?
  longitude      Float?
  description    String?
  active         Boolean  @default(true)
  ownerCompany   Company  @relation("WorkspaceOwner", fields: [ownerCompanyId], references: [id], onDelete: Restrict)
  ownerCompanyId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  users                      User[]
  scaffolds                  Scaffold[]
  inspections                Inspection[]
  nonConformities            NonConformity[]
  auditLogs                  AuditLog[]
  scaffoldDocuments          ScaffoldDocument[]
  documents                  Document[]
  nonConformityEvidences     NonConformityEvidence[]
  nonConformityItemEvidences NonConformityItemEvidence[]
  inspectionSignatures       InspectionSignature[]
  companyLinks               CompanyWorkspace[]

  @@index([ownerCompanyId, active])
  @@map("workspaces")
}

model CompanyWorkspace {
  id          String               @id @default(cuid())
  company     Company              @relation(fields: [companyId], references: [id], onDelete: Restrict)
  companyId   String
  workspace   Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  workspaceId String
  role        CompanyWorkspaceRole
  active      Boolean              @default(true)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@unique([companyId, workspaceId])
  @@index([workspaceId, role, active])
  @@index([companyId, active])
  @@map("company_workspaces")
}

// ──────────────────────────────────────────────────────────────────────────────
// Scaffold
// ──────────────────────────────────────────────────────────────────────────────

model Scaffold {
  id                    String         @id @default(cuid())
  code                  String         @unique // ex: AND-001
  tag                   String         @unique // QR tag = id (gerado automaticamente)
  type                  ScaffoldType
  status                ScaffoldStatus @default(em_montagem)
  location              String
  area                  String
  height                Float // metros
  width                 Float?
  length                Float?
  max_load              Float? // kg
  responsible           String
  company               String? // empresa montadora
  notes                 String?
  validity_date         DateTime?
  assembly_completed_at DateTime? // data conclusão montagem → PENDENTE_LIBERACAO
  released_at           DateTime? // data liberação → LIBERADO
  dismantled_at         DateTime? // data desmontagem → DESMONTADO

  latitude             Float?
  longitude            Float?
  location_description String?

  tenantCompany Company   @relation(fields: [companyId], references: [id], onDelete: Restrict)
  companyId     String    @default("company-hydro-alunorte")
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  workspaceId   String    @default("workspace-hydro-murucupi")

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  inspections     Inspection[]
  documents       ScaffoldDocument[]
  nonConformities NonConformity[]

  @@index([companyId])
  @@index([workspaceId])
  @@index([workspaceId, companyId])
  @@map("scaffolds")
}

// ──────────────────────────────────────────────────────────────────────────────
// ScaffoldDocument
// ──────────────────────────────────────────────────────────────────────────────

model ScaffoldDocument {
  id            String       @id @default(cuid())
  scaffold      Scaffold     @relation(fields: [scaffold_id], references: [id], onDelete: Cascade)
  scaffold_id   String
  type          DocumentType
  title         String
  file_url      String // referencia do arquivo no storage
  file_name     String
  file_size     Int? // bytes
  mime_type     String?
  uploaded_by   String // nome do responsável
  expires_at    DateTime? // data de validade/revisão (opcional)
  observation   String?
  tenantCompany Company      @relation(fields: [companyId], references: [id], onDelete: Restrict)
  companyId     String       @default("company-hydro-alunorte")
  workspace     Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  workspaceId   String       @default("workspace-hydro-murucupi")
  created_at    DateTime     @default(now())
  updated_at    DateTime     @updatedAt

  @@index([companyId])
  @@index([workspaceId])
  @@map("scaffold_documents")
}

model Document {
  id          String           @id @default(cuid())
  title       String
  description String?
  fileName    String
  fileUrl     String
  fileSize    Int?
  mimeType    String?
  category    DocumentCategory
  status      DocumentStatus   @default(ACTIVE)
  issueDate   DateTime?
  expiryDate  DateTime?
  companyId   String?
  workspaceId String?
  createdById String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  company   Company?   @relation(fields: [companyId], references: [id], onDelete: Restrict)
  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  createdBy User       @relation(fields: [createdById], references: [id], onDelete: Restrict)

  @@index([companyId])
  @@index([workspaceId])
  @@index([category])
  @@index([status])
  @@index([expiryDate])
  @@map("documents")
}

// ──────────────────────────────────────────────────────────────────────────────
// Inspection
// ──────────────────────────────────────────────────────────────────────────────

model Inspection {
  id            String   @id @default(cuid())
  scaffold      Scaffold @relation(fields: [scaffold_id], references: [id], onDelete: Cascade)
  scaffold_id   String
  scaffold_code String // desnormalizado para relatórios

  date           DateTime         @default(now())
  inspector_name String
  result         InspectionResult
  validity_days  Int              @default(0)
  notes          String?
  photos         String[] // referencias das fotos no storage
  signature      String? // referencia da assinatura no storage

  tenantCompany Company   @relation(fields: [companyId], references: [id], onDelete: Restrict)
  companyId     String    @default("company-hydro-alunorte")
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  workspaceId   String    @default("workspace-hydro-murucupi")

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  checklist       ChecklistEntry[]
  signatures      InspectionSignature[]
  nonConformities NonConformity[]

  @@index([companyId])
  @@index([workspaceId])
  @@index([workspaceId, companyId])
  @@map("inspections")
}

// ──────────────────────────────────────────────────────────────────────────────
// ChecklistEntry
// ──────────────────────────────────────────────────────────────────────────────

model ChecklistEntry {
  id            String     @id @default(cuid())
  inspection    Inspection @relation(fields: [inspection_id], references: [id], onDelete: Cascade)
  inspection_id String

  item_id     String // ex: "ITEM_01"
  item_label  String
  category    String
  value       ChecklistValue
  critical    Boolean        @default(false)
  observation String?
  photo       String? // referencia da foto no storage

  nonConformityItems NonConformityChecklistItem[]

  @@map("checklist_entries")
}

// ──────────────────────────────────────────────────────────────────────────────
// User
// ──────────────────────────────────────────────────────────────────────────────

model NonConformity {
  id             String                      @id @default(cuid())
  code           String                      @unique
  title          String
  description    String
  classification NonConformityClassification
  status         NonConformityStatus         @default(OPEN)

  originInspection   Inspection @relation(fields: [originInspectionId], references: [id], onDelete: Cascade)
  originInspectionId String
  scaffold           Scaffold   @relation(fields: [scaffoldId], references: [id], onDelete: Cascade)
  scaffoldId         String

  tenantCompany     Company   @relation(fields: [companyId], references: [id], onDelete: Restrict)
  companyId         String    @default("company-hydro-alunorte")
  workspace         Workspace @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  workspaceId       String    @default("workspace-hydro-murucupi")
  responsibleUser   User?     @relation("NonConformityResponsible", fields: [responsibleUserId], references: [id], onDelete: SetNull)
  responsibleUserId String?
  dueDate           DateTime?
  closedAt          DateTime?
  createdBy         User?     @relation("NonConformityCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdById       String?

  checklistItems NonConformityChecklistItem[]
  evidences      NonConformityEvidence[]
  history        NonConformityHistory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([originInspectionId])
  @@index([scaffoldId])
  @@index([companyId])
  @@index([workspaceId])
  @@index([workspaceId, companyId])
  @@index([responsibleUserId])
  @@index([classification])
  @@index([status])
  @@index([dueDate])
  @@map("non_conformities")
}

model NonConformityChecklistItem {
  id               String         @id @default(cuid())
  nonConformity    NonConformity  @relation(fields: [nonConformityId], references: [id], onDelete: Cascade)
  nonConformityId  String
  checklistEntry   ChecklistEntry @relation(fields: [checklistEntryId], references: [id], onDelete: Cascade)
  checklistEntryId String

  evidences NonConformityItemEvidence[]

  createdAt DateTime @default(now())

  @@unique([nonConformityId, checklistEntryId])
  @@index([checklistEntryId])
  @@map("non_conformity_checklist_items")
}

model NonConformityItemEvidence {
  id                  String                     @id @default(cuid())
  nonConformityItem   NonConformityChecklistItem @relation(fields: [nonConformityItemId], references: [id], onDelete: Cascade)
  nonConformityItemId String
  type                NonConformityEvidenceType
  title               String
  fileUrl             String
  fileName            String
  fileSize            Int?
  mimeType            String?
  uploadedBy          User?                      @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
  uploadedById        String?
  observation         String?
  tenantCompany       Company                    @relation(fields: [companyId], references: [id], onDelete: Restrict)
  companyId           String                     @default("company-hydro-alunorte")
  workspace           Workspace                  @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  workspaceId         String                     @default("workspace-hydro-murucupi")
  createdAt           DateTime                   @default(now())

  @@index([nonConformityItemId])
  @@index([type])
  @@index([uploadedById])
  @@index([companyId])
  @@index([workspaceId])
  @@map("non_conformity_item_evidences")
}

model NonConformityEvidence {
  id              String                    @id @default(cuid())
  nonConformity   NonConformity             @relation(fields: [nonConformityId], references: [id], onDelete: Cascade)
  nonConformityId String
  type            NonConformityEvidenceType
  title           String
  fileUrl         String
  fileName        String
  fileSize        Int?
  mimeType        String?
  uploadedBy      User?                     @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
  uploadedById    String?
  observation     String?
  tenantCompany   Company                   @relation(fields: [companyId], references: [id], onDelete: Restrict)
  companyId       String                    @default("company-hydro-alunorte")
  workspace       Workspace                 @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  workspaceId     String                    @default("workspace-hydro-murucupi")
  createdAt       DateTime                  @default(now())

  @@index([nonConformityId])
  @@index([type])
  @@index([uploadedById])
  @@index([companyId])
  @@index([workspaceId])
  @@map("non_conformity_evidences")
}

model NonConformityHistory {
  id              String        @id @default(cuid())
  nonConformity   NonConformity @relation(fields: [nonConformityId], references: [id], onDelete: Cascade)
  nonConformityId String
  action          String
  description     String
  oldValue        Json?
  newValue        Json?
  user            User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId          String?
  createdAt       DateTime      @default(now())

  @@index([nonConformityId])
  @@index([userId])
  @@index([createdAt])
  @@map("non_conformity_history")
}

model User {
  id            String         @id @default(cuid())
  name          String
  email         String         @unique
  password_hash String
  role          LegacyUserRole @default(inspector)
  avatar_url    String?
  company       String?
  registration  String?
  department    String?
  position      String?
  is_active     Boolean        @default(true)
  tenantCompany Company        @relation(fields: [companyId], references: [id], onDelete: Restrict)
  companyId     String         @default("company-hydro-alunorte")
  workspace     Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  workspaceId   String         @default("workspace-hydro-murucupi")

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  roles                      UserRole[]
  signatures                 InspectionSignature[]
  responsibleNonConformities NonConformity[]             @relation("NonConformityResponsible")
  createdNonConformities     NonConformity[]             @relation("NonConformityCreatedBy")
  createdDocuments           Document[]
  nonConformityEvidences     NonConformityEvidence[]
  nonConformityItemEvidences NonConformityItemEvidence[]
  nonConformityHistory       NonConformityHistory[]

  @@index([companyId])
  @@index([workspaceId])
  @@map("users")
}

// ─────────────────────────────────────────────────────────────────────────────
// RBAC
// ─────────────────────────────────────────────────────────────────────────────

model Role {
  id          String  @id @default(cuid())
  code        String  @unique
  name        String
  description String?
  is_system   Boolean @default(true)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  users                 UserRole[]
  permissions           RolePermission[]
  signatureRequirements InspectionSignatureRequirement[]
  inspectionSignatures  InspectionSignature[]

  @@map("roles")
}

model Permission {
  id          String  @id @default(cuid())
  code        String  @unique
  name        String
  description String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  roles RolePermission[]

  @@map("permissions")
}

model RolePermission {
  id            String     @id @default(cuid())
  role          Role       @relation(fields: [role_id], references: [id], onDelete: Cascade)
  role_id       String
  permission    Permission @relation(fields: [permission_id], references: [id], onDelete: Cascade)
  permission_id String

  created_at DateTime @default(now())

  @@unique([role_id, permission_id])
  @@map("role_permissions")
}

model UserRole {
  id          String   @id @default(cuid())
  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id     String
  role        Role     @relation(fields: [role_id], references: [id], onDelete: Cascade)
  role_id     String
  assigned_by String?
  assigned_at DateTime @default(now())

  @@unique([user_id, role_id])
  @@map("user_roles")
}

// ─────────────────────────────────────────────────────────────────────────────
// Inspection Signature Policies
// ─────────────────────────────────────────────────────────────────────────────

model InspectionSignaturePolicy {
  id            String        @id @default(cuid())
  name          String
  description   String?
  company       String?
  area          String?
  scaffold_type ScaffoldType?
  is_default    Boolean       @default(false)
  is_active     Boolean       @default(true)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  requirements InspectionSignatureRequirement[]

  @@index([is_active, is_default])
  @@index([company])
  @@index([area])
  @@index([scaffold_type])
  @@map("inspection_signature_policies")
}

model InspectionSignatureRequirement {
  id          String                    @id @default(cuid())
  policy      InspectionSignaturePolicy @relation(fields: [policy_id], references: [id], onDelete: Cascade)
  policy_id   String
  role        Role                      @relation(fields: [role_code], references: [code], onDelete: Restrict)
  role_code   String
  label       String?
  min_count   Int                       @default(1)
  is_required Boolean                   @default(true)
  sort_order  Int                       @default(0)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([policy_id, role_code])
  @@index([role_code])
  @@map("inspection_signature_requirements")
}

model InspectionSignature {
  id                  String     @id @default(cuid())
  inspection          Inspection @relation(fields: [inspection_id], references: [id], onDelete: Cascade)
  inspection_id       String
  user                User?      @relation(fields: [user_id], references: [id], onDelete: SetNull)
  user_id             String?
  role                Role       @relation(fields: [role_code], references: [code], onDelete: Restrict)
  role_code           String
  signer_name         String
  signer_company      String?
  signer_position     String?
  signature_image_url String?
  signature_data      String? // referencia da assinatura no storage
  tenantCompany       Company    @relation(fields: [companyId], references: [id], onDelete: Restrict)
  companyId           String     @default("company-hydro-alunorte")
  workspace           Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  workspaceId         String     @default("workspace-hydro-murucupi")
  signed_at           DateTime   @default(now())
  created_at          DateTime   @default(now())

  @@index([inspection_id])
  @@index([user_id])
  @@index([role_code])
  @@index([companyId])
  @@index([workspaceId])
  @@map("inspection_signatures")
}

model AuditLog {
  id            String          @id @default(cuid())
  userId        String?
  userName      String?
  userRole      String?
  entityType    AuditEntityType
  entityId      String?
  entityLabel   String?
  action        AuditAction
  description   String
  oldValue      Json?
  newValue      Json?
  ipAddress     String?
  userAgent     String?
  workspace     Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  workspaceId   String          @default("workspace-hydro-murucupi")
  tenantCompany Company         @relation(fields: [companyId], references: [id], onDelete: Restrict)
  companyId     String          @default("company-hydro-alunorte")
  createdAt     DateTime        @default(now())

  @@index([createdAt])
  @@index([entityType, entityId])
  @@index([action])
  @@index([userId])
  @@index([companyId])
  @@index([workspaceId])
  @@map("audit_logs")
}
