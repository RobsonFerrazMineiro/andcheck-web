// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ──────────────────────────────────────────────────────────────────────────────
// Enums
// ──────────────────────────────────────────────────────────────────────────────

enum ScaffoldStatus {
  em_montagem
  pendente_liberacao
  liberado
  reprovado
  interditado
  vencido
  desmontado
}

enum ScaffoldType {
  tubular
  fachadeiro
  multidirecional
  suspenso
  torre
}

enum InspectionResult {
  aprovado
  aprovado_com_ressalvas
  reprovado
}

enum ChecklistValue {
  CL_OK
  CL_FAIL
  CL_WARN
  CL_NA
}

enum LegacyUserRole {
  admin
  inspector
  viewer

  @@map("UserRole")
}

enum DocumentType {
  ART
  RRT
  MEMORIAL_CALCULO
  CROQUI
  PROJETO
  PROCEDIMENTO
  CERTIFICADO
  OUTRO
}

enum AuditEntityType {
  SCAFFOLD
  INSPECTION
  DOCUMENT
  USER
  SIGNATURE
  PDF
  QR_CODE
  SETTINGS
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  STATUS_CHANGE
  SIGN
  COMPLETE
  UPLOAD
  DOWNLOAD
  GENERATE_PDF
  VIEW_QR
  LOGIN
  LOGOUT
  ROLE_CHANGE
}


// ──────────────────────────────────────────────────────────────────────────────
// Scaffold
// ──────────────────────────────────────────────────────────────────────────────

model Scaffold {
  id           String         @id @default(cuid())
  code         String         @unique          // ex: AND-001
  tag          String         @unique          // QR tag = id (gerado automaticamente)
  type         ScaffoldType
  status       ScaffoldStatus @default(em_montagem)
  location     String
  area         String
  height       Float                           // metros
  width        Float?
  length       Float?
  max_load     Float?                          // kg
  responsible  String
  company      String?                         // empresa montadora
  notes        String?
  validity_date DateTime?
  assembly_completed_at DateTime?   // data conclusão montagem → PENDENTE_LIBERACAO
  released_at           DateTime?   // data liberação → LIBERADO
  dismantled_at         DateTime?   // data desmontagem → DESMONTADO

  latitude          Float?
  longitude         Float?
  location_description String?

  created_at   DateTime       @default(now())
  updated_at   DateTime       @updatedAt

  inspections  Inspection[]
  documents    ScaffoldDocument[]

  @@map("scaffolds")
}

// ──────────────────────────────────────────────────────────────────────────────
// ScaffoldDocument
// ──────────────────────────────────────────────────────────────────────────────

model ScaffoldDocument {
  id            String       @id @default(cuid())
  scaffold      Scaffold     @relation(fields: [scaffold_id], references: [id], onDelete: Cascade)
  scaffold_id   String
  type          DocumentType
  title         String
  file_url      String       // base64 ou URL do arquivo
  file_name     String
  file_size     Int?         // bytes
  mime_type     String?
  uploaded_by   String       // nome do responsável
  expires_at    DateTime?    // data de validade/revisão (opcional)
  observation   String?
  created_at    DateTime     @default(now())
  updated_at    DateTime     @updatedAt

  @@map("scaffold_documents")
}

// ──────────────────────────────────────────────────────────────────────────────
// Inspection
// ──────────────────────────────────────────────────────────────────────────────

model Inspection {
  id              String            @id @default(cuid())
  scaffold        Scaffold          @relation(fields: [scaffold_id], references: [id], onDelete: Cascade)
  scaffold_id     String
  scaffold_code   String            // desnormalizado para relatórios

  date            DateTime          @default(now())
  inspector_name  String
  result          InspectionResult
  validity_days   Int               @default(0)
  notes           String?
  photos          String[]          // base64 ou URLs das fotos
  signature       String?           // base64 da assinatura digital

  created_at      DateTime          @default(now())
  updated_at      DateTime          @updatedAt

  checklist       ChecklistEntry[]
  signatures      InspectionSignature[]

  @@map("inspections")
}

// ──────────────────────────────────────────────────────────────────────────────
// ChecklistEntry
// ──────────────────────────────────────────────────────────────────────────────

model ChecklistEntry {
  id             String          @id @default(cuid())
  inspection     Inspection      @relation(fields: [inspection_id], references: [id], onDelete: Cascade)
  inspection_id  String

  item_id        String          // ex: "ITEM_01"
  item_label     String
  category       String
  value          ChecklistValue
  critical       Boolean         @default(false)
  observation    String?
  photo          String?         // base64 da foto do item não conforme

  @@map("checklist_entries")
}

// ──────────────────────────────────────────────────────────────────────────────
// User
// ──────────────────────────────────────────────────────────────────────────────

model User {
  id             String          @id @default(cuid())
  name           String
  email          String          @unique
  password_hash  String
  role           LegacyUserRole  @default(inspector)
  avatar_url     String?
  company        String?
  registration   String?
  department     String?
  position       String?
  is_active      Boolean         @default(true)

  created_at     DateTime        @default(now())
  updated_at     DateTime        @updatedAt

  roles          UserRole[]
  signatures     InspectionSignature[]

  @@map("users")
}

// ─────────────────────────────────────────────────────────────────────────────
// RBAC
// ─────────────────────────────────────────────────────────────────────────────

model Role {
  id          String  @id @default(cuid())
  code        String  @unique
  name        String
  description String?
  is_system   Boolean @default(true)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  users       UserRole[]
  permissions RolePermission[]
  signatureRequirements InspectionSignatureRequirement[]
  inspectionSignatures  InspectionSignature[]

  @@map("roles")
}

model Permission {
  id          String  @id @default(cuid())
  code        String  @unique
  name        String
  description String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  roles RolePermission[]

  @@map("permissions")
}

model RolePermission {
  id            String     @id @default(cuid())
  role          Role       @relation(fields: [role_id], references: [id], onDelete: Cascade)
  role_id       String
  permission    Permission @relation(fields: [permission_id], references: [id], onDelete: Cascade)
  permission_id String

  created_at DateTime @default(now())

  @@unique([role_id, permission_id])
  @@map("role_permissions")
}

model UserRole {
  id          String   @id @default(cuid())
  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id     String
  role        Role     @relation(fields: [role_id], references: [id], onDelete: Cascade)
  role_id     String
  assigned_by String?
  assigned_at DateTime @default(now())

  @@unique([user_id, role_id])
  @@map("user_roles")
}

// ─────────────────────────────────────────────────────────────────────────────
// Inspection Signature Policies
// ─────────────────────────────────────────────────────────────────────────────

model InspectionSignaturePolicy {
  id            String        @id @default(cuid())
  name          String
  description   String?
  company       String?
  area          String?
  scaffold_type ScaffoldType?
  is_default    Boolean       @default(false)
  is_active     Boolean       @default(true)

  created_at    DateTime      @default(now())
  updated_at    DateTime      @updatedAt

  requirements  InspectionSignatureRequirement[]

  @@index([is_active, is_default])
  @@index([company])
  @@index([area])
  @@index([scaffold_type])
  @@map("inspection_signature_policies")
}

model InspectionSignatureRequirement {
  id          String                    @id @default(cuid())
  policy      InspectionSignaturePolicy @relation(fields: [policy_id], references: [id], onDelete: Cascade)
  policy_id   String
  role        Role                      @relation(fields: [role_code], references: [code], onDelete: Restrict)
  role_code   String
  label       String?
  min_count   Int                       @default(1)
  is_required Boolean                   @default(true)
  sort_order  Int                       @default(0)

  created_at  DateTime                  @default(now())
  updated_at  DateTime                  @updatedAt

  @@unique([policy_id, role_code])
  @@index([role_code])
  @@map("inspection_signature_requirements")
}

model InspectionSignature {
  id                  String      @id @default(cuid())
  inspection          Inspection  @relation(fields: [inspection_id], references: [id], onDelete: Cascade)
  inspection_id       String
  user                User?       @relation(fields: [user_id], references: [id], onDelete: SetNull)
  user_id             String?
  role                Role        @relation(fields: [role_code], references: [code], onDelete: Restrict)
  role_code           String
  signer_name         String
  signer_company      String?
  signer_position     String?
  signature_image_url String?
  signature_data      String?
  signed_at           DateTime    @default(now())
  created_at          DateTime    @default(now())

  @@index([inspection_id])
  @@index([user_id])
  @@index([role_code])
  @@map("inspection_signatures")
}

model AuditLog {
  id          String          @id @default(cuid())
  userId      String?
  userName    String?
  userRole    String?
  entityType  AuditEntityType
  entityId    String?
  entityLabel String?
  action      AuditAction
  description String
  oldValue    Json?
  newValue    Json?
  ipAddress   String?
  userAgent   String?
  workspaceId String?
  companyId   String?
  createdAt   DateTime        @default(now())

  @@index([createdAt])
  @@index([entityType, entityId])
  @@index([action])
  @@index([userId])
  @@index([companyId])
  @@map("audit_logs")
}
