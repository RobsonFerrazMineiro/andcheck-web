# Homologacao publicada
DATABASE_URL=

# Auth.js / URL publica
AUTH_SECRET=
AUTH_URL=https://andcheck-homolog.example.com
NEXTAUTH_URL=https://andcheck-homolog.example.com
NEXT_PUBLIC_APP_URL=https://andcheck-homolog.example.com

# Scheduled jobs
NOTIFICATION_CRON_SECRET=

# Offline/PWA
NEXT_PUBLIC_ENABLE_SERVICE_WORKER=true

# Email notifications
# Para homologar sem e-mail real, mantenha mock e registre a pendencia.
# Para validar envio real, troque EMAIL_PROVIDER e preencha as credenciais.
EMAIL_NOTIFICATIONS_ENABLED=true
EMAIL_PROVIDER=mock
EMAIL_FROM="AndCheck Homolog <notificacoes-homolog@example.com>"
RESEND_API_KEY=
SENDGRID_API_KEY=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# Vercel Blob uploads
BLOB_READ_WRITE_TOKEN=
BLOB_STORE_ID=

# Vercel / Neon integration
VERCEL_OIDC_TOKEN=
